# ── Video source ──────────────────────────────────────────────
# Path to your downloaded demo video (relative to backend/)
# Leave empty to run in mock mode (Phase 1 fallback)
VIDEO_SOURCE=videos/demo.mp4

# ── Camera metadata (shown on the dashboard card) ─────────────
CAMERA_ID=cam-001
CAMERA_NAME=Demo Feed
CAMERA_VENUE=Main Hall

# ── Occupancy thresholds ──────────────────────────────────────
# These apply to all 9 grid cells. Phase 3 adds per-cell config.
WARN_THRESHOLD=10
CRITICAL_THRESHOLD=20

# ── ML config ─────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5
# Seconds between WebSocket broadcasts (lower = more responsive)
BROADCAST_INTERVAL=2.0

# ── Data layer (Phase 3) ──────────────────────────────────────
DATABASE_URL=postgresql://argus:argus@localhost:5432/argus
REDIS_URL=redis://localhost:6379
